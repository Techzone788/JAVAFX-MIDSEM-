<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #0F2027;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.MainController">  <!-- Deep teal background -->

    <!-- TOP HEADER -->
    <top>
        <VBox spacing="10" style="-fx-background-color: #203A43; -fx-padding: 20;">

            <Label style="-fx-font-size: 26px;                           -fx-text-fill: #00C9A7;                           -fx-font-weight: bold;" text="Student Management System" />

            <!-- ACTION BAR -->
            <HBox spacing="10">

                <Button fx:id="addStudentButton" onAction="#handleAddStudent" style="-fx-background-color: #00C9A7; -fx-text-fill: black;" text="Add" />

                <Button fx:id="editStudentButton" onAction="#handleEditStudent" style="-fx-background-color: #22C55E; -fx-text-fill: white;" text="Edit" />

                <Button fx:id="deleteStudentButton" onAction="#handleDeleteStudent" style="-fx-background-color: #EF4444; -fx-text-fill: white;" text="Delete" />

                <Button fx:id="clearButton" onAction="#handleClearForm" style="-fx-background-color: #64748B; -fx-text-fill: white;" text="Clear" />

                <Button fx:id="reportsButton" onAction="#openReportsWindow" style="-fx-background-color: #8B5CF6; -fx-text-fill: white;" text="Reports" />

                <Region HBox.hgrow="ALWAYS" />

                <ComboBox fx:id="programmeFilter" onAction="#handleProgrammeFilter" prefWidth="160" promptText="Filter by Program" />

                <Button onAction="#handleSortByGpa" style="-fx-background-color: #334155; -fx-text-fill: white;" text="Sort by GPA" />

                <Button onAction="#handleSortByName" style="-fx-background-color: #334155; -fx-text-fill: white;" text="Sort by Name" />
            </HBox>
        </VBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- TABLE -->
            <TableView fx:id="studentTable" style="-fx-background-color: #203A43;                               -fx-control-inner-background: #0F2027;                               -fx-text-fill: white;" HBox.hgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="idColumn" text="Student ID" />
                    <TableColumn fx:id="nameColumn" text="Full Name" />
                    <TableColumn fx:id="programmeColumn" text="Programme" />
                    <TableColumn fx:id="levelColumn" text="Level" />
                    <TableColumn fx:id="gpaColumn" text="GPA" />
                    <TableColumn fx:id="emailColumn" text="Email" />
                    <TableColumn fx:id="phoneColumn" text="Phone" />
                </columns>
            </TableView>

            <!-- HORIZONTAL FORM -->
            <GridPane hgap="15" prefWidth="450" style="-fx-background-color: #203A43;                              -fx-padding: 20;                              -fx-background-radius: 10;" vgap="15">

                <!-- Row 1 -->
                <Label style="-fx-text-fill: white;" text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="studentIdField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label style="-fx-text-fill: white;" text="Full Name:" GridPane.columnIndex="2" />
                <TextField fx:id="fullNameField" GridPane.columnIndex="3" />

                <!-- Row 2 -->
                <Label style="-fx-text-fill: white;" text="Programme:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="programmeField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label style="-fx-text-fill: white;" text="Level:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                <TextField fx:id="levelField" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                <!-- Row 3 -->
                <Label style="-fx-text-fill: white;" text="GPA:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="gpaField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label style="-fx-text-fill: white;" text="Email:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                <TextField fx:id="emailField" GridPane.columnIndex="3" GridPane.rowIndex="2" />

                <!-- Row 4 -->
                <Label style="-fx-text-fill: white;" text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <columnConstraints>
                    <ColumnConstraints percentWidth="15.0" />
                    <ColumnConstraints percentWidth="35.0" />
                    <ColumnConstraints percentWidth="15.0" />
                    <ColumnConstraints percentWidth="35.0" />
                </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>

            </GridPane>

        </HBox>
    </center>

</BorderPane>
