<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #0F2027;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.UI.ReportsController">

    <!-- HEADER -->
    <top>
        <VBox spacing="10" style="-fx-background-color: #203A43; -fx-padding: 20;">

            <Label style="-fx-text-fill: #00C9A7;                           -fx-font-size: 22px;                           -fx-font-weight: bold;" text="Student Reports" />

            <HBox alignment="CENTER_LEFT" spacing="15">

                <Label style="-fx-text-fill: white;" text="Minimum GPA:" />

                <TextField fx:id="gpaThresholdField" prefWidth="120" promptText="Enter GPA" style="-fx-background-color: #0F2027;                                   -fx-text-fill: white;                                   -fx-border-color: #00C9A7;" />

                <Button onAction="#handleLoadReport" style="-fx-background-color: #00C9A7;                                -fx-text-fill: black;" text="Generate" />

                <Button onAction="#handleClearReport" style="-fx-background-color: #F59E0B;                                -fx-text-fill: black;" text="Clear" />

                <Region HBox.hgrow="ALWAYS" />

                <Button onAction="#handleImportCSV" style="-fx-background-color: #2C5364;                                -fx-text-fill: white;" text="CSV IMPORT" />

                <Button onAction="#handleExportCSV" style="-fx-background-color: #2C5364;                                -fx-text-fill: white;" text="CSV EXPORT" />

            </HBox>
        </VBox>
    </top>

    <!-- TABLE -->
    <center>
        <VBox style="-fx-padding: 25;">

            <TableView fx:id="reportTable" style="-fx-control-inner-background: #203A43;                               -fx-border-color: #00C9A7;                               -fx-text-fill: white;" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="100" text="Student ID" />
                    <TableColumn fx:id="nameColumn" prefWidth="150" text="Full Name" />
                    <TableColumn fx:id="programmeColumn" prefWidth="120" text="Programme" />
                    <TableColumn fx:id="levelColumn" prefWidth="80" text="Level" />
                    <TableColumn fx:id="gpaColumn" prefWidth="80" text="GPA" />
                    <TableColumn fx:id="emailColumn" prefWidth="170" text="Email" />
                    <TableColumn fx:id="phoneColumn" prefWidth="120" text="Phone" />
               <TableColumn prefWidth="75.0" text="Status" />
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>
